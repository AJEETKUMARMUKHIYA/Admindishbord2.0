# API Configuration
VITE_API_BASE_URL=https://packyatra.in/api
VITE_API_TIMEOUT=10000
VITE_API_RETRY_ATTEMPTS=3

# App Configuration
VITE_APP_NAME="Admin Dashboard"
VITE_APP_VERSION=2.0

# Feature Flags
VITE_FEATURE_EXPORT=true
VITE_FEATURE_NOTIFICATIONS=true
VITE_FEATURE_ANALYTICS=true

# Development Settings
VITE_DEFAULT_USERNAME=admin
VITE_DEFAULT_PASSWORD=123
VITE_MOCK_API=false

# Validation
VITE_PASSWORD_MIN_LENGTH=6
VITE_USERNAME_MIN_LENGTH=3
